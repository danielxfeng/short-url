{
  "name": "backend-ktor",
  "private": true,
  "version": "1.0.0",
  "description": "Ktor backend scripts exposed through the pnpm workspace",
  "scripts": {
    "lint": "./gradlew ktlintCheck",
    "format": "./gradlew ktlintFormat",
    "test": "./gradlew test",
    "build": "./gradlew build",
    "dev": "./gradlew run",
    "precommit": "pnpm run lint && pnpm run test && pnpm run build",
    "start": "./gradlew run",
    "jar": "./gradlew buildFatJar",
    "docker:build": "./gradlew buildImage",
    "docker:publish:local": "./gradlew publishImageToLocalRegistry"
  },
  "packageManager": "pnpm@10.33.2"
}
